# Activate a project environment interactively in a session whose default
# environment is already active, so the shell rc file's eval of
# `flox activate -d <default>` is a repeat activation. A repeat activation
# adds no layer, so the interactive layer is the only one this session owns
# and a single plain `flox deactivate` exits the session.
#
# argv: <dir> <marker>
#   marker  value of DEFAULT_MARKER set by the default env's [vars]

set dir [lindex $argv 0]
set marker [lindex $argv 1]
set flox $env(FLOX_BIN)
set timeout 10
set env(NO_COLOR) 1
set env(TERM) xterm-mono
set stty_init "cols 1000"

spawn $flox activate --dir $dir
expect_after {
  timeout { exit 1 }
  eof { exit 2 }
  "*\n" { exp_continue }
  "*\r" { exp_continue }
}

expect "You are now using the environment"
expect $env(KNOWN_PROMPT)

# The default env's vars are still present after the repeat activation.
send "echo marker_\"\$DEFAULT_MARKER\"\r"
expect -ex "marker_$marker"
expect $env(KNOWN_PROMPT)

send "$flox deactivate\r"
expect eof

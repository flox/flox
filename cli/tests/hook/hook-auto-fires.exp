# Verify that the prompt hook auto-fires in an interactive shell.
# After activation, _FLOX_HOOK_FIRED should be set without manually
# calling _flox_hook — the prompt hook mechanism triggers it.

set dir [lindex $argv 0]
set flox $env(FLOX_BIN)
set env(NO_COLOR) 1
set env(TERM) xterm-mono
set stty_init "cols 1000"

set timeout 20
exp_internal 1

spawn $flox activate --dir $dir
expect_after {
  timeout { exit 1 }
  eof { exit 2 }
  "*\n" { exp_continue }
  "*\r" { exp_continue }
}

# Wait for prompt to appear (hook should have fired by now)
expect $env(KNOWN_PROMPT)

# Check that the hook auto-fired by reading _FLOX_HOOK_FIRED
send "printenv _FLOX_HOOK_FIRED\n"
expect -re "/.*"
expect $env(KNOWN_PROMPT)

send "exit\n"
expect eof

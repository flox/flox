#!/usr/bin/env bash
# shellcheck shell=bash

# Trace levels supported by activation scripts:
#   1. (-v) top-level activate script
#   2. (-vv) language-specific profile scripts
#   3. (-vvv) zsh `autoload -U compinit` (very verbose)
export _flox_activate_tracelevel="${_FLOX_SUBSYSTEM_VERBOSITY:-0}"
[ "$_flox_activate_tracelevel" -eq 0 ] || set -x

# Ensure that $_flox_activate_tracer is defined as an executable.
# Auto-enable tracing when profiling is active.
if [ -n "${FLOX_PROFILE:-}" ] && [ -z "${FLOX_ACTIVATE_TRACE-}" ]; then
  export FLOX_ACTIVATE_TRACE=1
fi
if [ -z "${FLOX_ACTIVATE_TRACE-}" ]; then
  # Use a bash no-op function instead of external `true` command.
  # Saves ~0.5ms per invocation (8+ calls in this script = ~4ms total).
  _trace() { :; }
  export _flox_activate_tracer=true
else
  # If FLOX_ACTIVATE_TRACE is set but does not refer to an executable, then
  # set _flox_activate_tracer to the default trace script.
  if [ -x "${FLOX_ACTIVATE_TRACE:-}" ]; then
    export _flox_activate_tracer="$FLOX_ACTIVATE_TRACE"
  else
    export _flox_activate_tracer="__OUT__/activate.d/trace"
  fi
  _trace() { "$_flox_activate_tracer" "$@"; }
fi
_trace "${BASH_SOURCE[0]}" "$@" START

_flox_activations="@flox_activations@"
_ld_floxlib_so="@ld_floxlib@/lib/ld-floxlib.so"
_ldconfig="@iconv@/bin/ldconfig"
_findutils="@findutils@/bin/find"

set -euo pipefail

# These all derive from the `flox-interpreter` package.
export _activate_d="__OUT__/activate.d"

# Options can come from env vars (fast path from Rust caller) or CLI args
# (standalone invocation / tests).
if [ -n "${_FLOX_ACTIVATE_ENV:-}" ]; then
  # Fast path: read from environment variables (no getopt fork needed)
  _FLOX_ENV="$_FLOX_ACTIVATE_ENV"
  _FLOX_ENV_ACTIVATION_MODE="${_FLOX_ACTIVATE_MODE:-dev}"
  _start_state_dir="${_FLOX_ACTIVATE_START_STATE_DIR:-}"
  _skip_hook_on_activate="false"
  # No command mode when called from Rust (commands are handled there)
  _command_mode="false"
else
  # Fallback: parse CLI args for standalone/test invocation.
  # Source helpers only in fallback path (provides source_profile_d,
  # set_manifest_vars for standalone/test use). The Rust fast path
  # inlines set_manifest_vars and uses setup-env instead of profile.d.
  # shellcheck source-path=SCRIPTDIR/activate.d
  source "${_activate_d}/helpers.bash"
  _getopt="@getopt@/bin/getopt"
  OPTIONS="e:c:m:"
  LONGOPTS="command:,env:,env-project:,mode:,start-state-dir:,skip-hook-on-activate"
  if ! PARSED=$("$_getopt" --options="$OPTIONS" --longoptions="$LONGOPTS" --name "$0" -- "$@"); then
    echo "Failed to parse options." >&2
    exit 1
  fi
  eval set -- "$PARSED"

  FLOX_CMD=""
  _FLOX_ENV_ACTIVATION_MODE="dev"
  _skip_hook_on_activate="false"
  while true; do
    case "$1" in
      -c | --command)
        shift; FLOX_CMD="${1:-}"; shift ;;
      -e | --env)
        shift; _FLOX_ENV="$1"; shift ;;
      --env-project)
        shift; _FLOX_ENV_PROJECT="$1"; shift ;;
      -m | --mode)
        shift; _FLOX_ENV_ACTIVATION_MODE="$1"; shift ;;
      --start-state-dir)
        shift; _start_state_dir="$1"; shift ;;
      --skip-hook-on-activate)
        _skip_hook_on_activate="true"; shift ;;
      --)
        shift; break ;;
      *)
        shift ;;
    esac
  done

  if [ -z "${_FLOX_ENV:-}" ]; then
    echo "Error: --env is required." >&2
    exit 1
  fi

  if [ -n "${FLOX_CMD:-}" ]; then
    set -- "$FLOX_CMD"
  fi

  if [ $# -gt 0 ]; then
    _command_mode="true"
  else
    _command_mode="false"
  fi
fi

if [ "$_command_mode" = "true" ]; then
  # Command mode (standalone invocation only)
  export FLOX_ENV="${_FLOX_ENV}"
  # shellcheck disable=SC2043
  for var_key in FLOX_ENV_PROJECT; do
    eval "var_val=\${_$var_key-}"
    if [ -n "$var_val" ]; then
      export $var_key="${var_val}"
    else
      unset $var_key
    fi
  done

  _trace "fix-env" START
  # shellcheck disable=SC1090
  source <("$_flox_activations" fix-env --shell bash --flox-env "$_FLOX_ENV" --env-dirs "${FLOX_ENV_DIRS:-}" --path "$PATH" --manpath "${MANPATH:-}")
  _trace "fix-env" END
fi

# Build setup-env arguments. This single Rust command replaces sourcing 4+
# shell scripts, spawning python3 for version detection, uname for platform
# detection, and find/ldconfig/nawk for CUDA.
_setup_env_args=(
  --mode "$_FLOX_ENV_ACTIVATION_MODE"
  --flox-env "$_FLOX_ENV"
  --env-dirs "${FLOX_ENV_DIRS:-}"
  --shell bash
  --ld-floxlib "$_ld_floxlib_so"
  --ldconfig "$_ldconfig"
  --find-bin "$_findutils"
)
if [ -n "${FLOX_ENV_PROJECT:-}" ]; then
  _setup_env_args+=(--env-project "$FLOX_ENV_PROJECT")
fi

if [ "$_command_mode" = "false" ]; then
  # Set umask to ensure files are created with 0600 (may contain secrets)
  umask 077
  _start_env_json="$_start_state_dir/start.env.json"
  _end_env_json="$_start_state_dir/end.env.json"
  # Combine env snapshot + profile.d setup into one process spawn.
  # The --dump-env-start flag writes start.env.json BEFORE computing
  # profile changes, saving one process spawn (~5-6ms).
  _setup_env_args+=(--dump-env-start "$_start_env_json")
fi

_trace "setup-env" START
# shellcheck disable=SC1090
source <("$_flox_activations" setup-env "${_setup_env_args[@]}")
_trace "setup-env" END

# Set static environment variables from the manifest (inlined from
# helpers.bash to avoid sourcing the full helpers file on the fast path).
_trace "set_manifest_vars" START
if [ -f "$_FLOX_ENV/activate.d/envrc" ]; then
  # shellcheck disable=SC1091 # from rendered environment
  source "$_FLOX_ENV/activate.d/envrc"
fi
_trace "set_manifest_vars" END

if [ "$_skip_hook_on_activate" = "false" ]; then
  # Source the hook-on-activate script if it exists.
  if [ -e "$_FLOX_ENV/activate.d/hook-on-activate" ]; then
    # Nothing good can come from output printed to stdout in the
    # user-provided hook scripts because these can get interpreted
    # as configuration statements by the "in-place" activation
    # mode. So, we'll redirect stdout to stderr.
    set +euo pipefail
    _trace "$_FLOX_ENV/activate.d/hook-on-activate" START
    # shellcheck disable=SC1091 # from rendered environment
    source "$_FLOX_ENV/activate.d/hook-on-activate" 1>&2
    _trace "$_FLOX_ENV/activate.d/hook-on-activate" END
    set -euo pipefail
  else
    _trace "$_FLOX_ENV/activate.d/hook-on-activate" NOT FOUND
  fi
fi

if [ "$_command_mode" = "true" ]; then
  if [ -n "${FLOX_CMD:-}" ]; then
    exec bash -c "$FLOX_CMD"
  else
    exec "$@"
  fi
fi

if [ "$_command_mode" = "false" ]; then
  # Capture ending environment.
  _trace "env-snapshot-end" START
  "$_flox_activations" dump-env -o "$_end_env_json"
  _trace "env-snapshot-end" END
fi

_trace "${BASH_SOURCE[0]}" "$@" END
